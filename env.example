# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_DB=retailpulse
POSTGRES_USER=retailuser
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Flask API ────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000
FLASK_SECRET_KEY=dev-secret-key-change-in-prod

# ─── PgAdmin (optional) ───────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@retailpulse.local
PGADMIN_DEFAULT_PASSWORD=admin

# ─── ETL ──────────────────────────────────────────────
ETL_BATCH_SIZE=1000
ETL_LOG_LEVEL=INFO
